{
  "name": "menakas-writings",
  "version": "1.0.0",
  "description": "A personalized theme based on the _s starter theme.",
  "author": "a.g.skryp",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "WordPress",
    "Theme"
  ],
  "homepage": "https://www.agskryp.com",
  "devDependencies": {
    "sass": "^1.101.0"
  },
  "scripts": {
    "compile": "sass sass/style.scss style.css --style=compressed",
    "watch": "sass --watch sass/style.scss style.css --style=expanded"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true
  },
  "dependencies": {
    "@picocss/pico": "^2.1.1"
  }
}
